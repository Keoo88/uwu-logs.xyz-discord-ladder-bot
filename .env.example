# ==== Discord ====
# Токен бота из https://discord.com/developers/applications -> Bot -> Reset Token
DISCORD_TOKEN=put-your-bot-token-here
# ID сервера (Guild) для мгновенной регистрации slash-команд (включи Developer Mode -> ПКМ по серверу -> Copy Server ID).
# Если пусто — команды регистрируются глобально (обновляются до часа).
DISCORD_GUILD_ID=

# ==== Источник данных ====
WARMANE_GUILD=RUnion
WARMANE_REALM=Icecrown
# Имя реалма для UwU Logs (обычно совпадает с realm)
UWU_SERVER=Icecrown

# Ранги, которые считаются "Raider+". Список через запятую (без регистра).
# Если пусто — берём ранги, содержащие gm / officer / raider.
RAIDER_RANKS=

# ==== Движок UwU Logs ====
# browser — читает рейтинг с отрисованной страницы (работает сразу).
# api     — бьёт напрямую в JSON-эндпоинт (быстрее; сначала найди его через discover.py).
UWU_MODE=browser

# Спеки, которые проверяем для каждого персонажа (берём лучший). 1,2,3 = три ветки талантов.
UWU_SPECS=1,2,3

# API-режим: шаблон URL (подставляются {name} {server} {spec}). Заполни после discover.py.
UWU_API_URL=
# JSON-ключи (через точку) до значения рейтинга и dps в ответе API.
UWU_API_RATING_PATH=
UWU_API_DPS_PATH=

# ==== Поведение ====
# Сколько строк показывать в ладдере по умолчанию.
LADDER_LIMIT=50
# TTL кеша в секундах (чтобы не пересканировать на каждый /ladder). 3600 = 1 час.
CACHE_TTL=3600
# Пауза между запросами к UwU (сек), чтобы не нагружать сайт.
UWU_REQUEST_DELAY=1.0
# Одновременные запросы к UwU (browser-режим держи 1-2).
UWU_CONCURRENCY=2
